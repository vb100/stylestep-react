{$APP_DOMAIN:localhost} {
    encode gzip zstd

    header {
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        X-Frame-Options SAMEORIGIN
    }

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /admin/* {
        reverse_proxy backend:8000
    }

    handle /media/* {
        root * /srv
        file_server
    }

    handle /static/* {
        root * /srv
        file_server
    }

    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }
}
